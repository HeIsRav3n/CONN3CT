{
  "name": "conn3ct-pnl",
  "version": "1.0.0",
  "description": "Enterprise-grade Discord NFT P&L Tracking Bot — OpenSea + Ethereum on-chain data",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:integration": "jest --config jest.integration.config.js --runInBand --forceExit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "deploy:commands": "ts-node src/bot/deploy-commands.ts",
    "worker:sync": "ts-node src/workers/syncWorker.ts",
    "worker:price": "ts-node src/workers/priceWorker.ts",
    "worker:pnl": "ts-node src/workers/pnlWorker.ts",
    "docker:build": "docker build -t conn3ct-pnl .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@bull-board/api": "^5.19.1",
    "@bull-board/express": "^5.19.1",
    "@napi-rs/canvas": "^1.0.0",
    "@prisma/client": "^5.22.0",
    "alchemy-sdk": "^2.0.2",
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "bullmq": "^5.13.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "prom-client": "^15.1.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
