# ============================================================
# CONN3CT PNL — Environment Configuration
# Copy this file to .env and fill in all values
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── Discord ──────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_test_guild_id_for_dev_command_registration

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://conn3ct:password@localhost:5432/conn3ct_pnl
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ── Cache (Redis) ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_TLS=false

# ── OpenSea API ──────────────────────────────────────────────
# Primary key — required
OPENSEA_API_KEY=your_opensea_api_key
# Optional rotation keys (comma-separated)
OPENSEA_API_KEYS=key1,key2,key3
OPENSEA_BASE_URL=https://api.opensea.io/api/v2
OPENSEA_RATE_LIMIT_RPS=4

# ── Ethereum / Alchemy ───────────────────────────────────────
# Just the key portion — NOT the full URL
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_NETWORK=eth-mainnet
# Full RPC URL: https://eth-mainnet.g.alchemy.com/v2/<your_key>
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key
ETHEREUM_RPC_FALLBACK=https://mainnet.infura.io/v3/your_infura_key

# ── ETH Price Feed ───────────────────────────────────────────
COINGECKO_API_KEY=your_coingecko_api_key
ETH_PRICE_CACHE_TTL=300

# ── BullMQ Workers ───────────────────────────────────────────
SYNC_WORKER_CONCURRENCY=5
PRICE_WORKER_CONCURRENCY=3
PNL_WORKER_CONCURRENCY=10
WALLET_SYNC_INTERVAL_MS=300000
PRICE_UPDATE_INTERVAL_MS=600000

# ── Security ─────────────────────────────────────────────────
API_SECRET_KEY=your_32_char_minimum_secret_key_here
ENCRYPTION_KEY=your_64_char_hex_string_32_bytes
JWT_SECRET=your_jwt_secret_for_api_auth

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ── Bull Board (Job Dashboard) ───────────────────────────────
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=secure_password_here
BULL_BOARD_PORT=3002
